#!/usr/bin/env python3
"""Unified dotfiles management script wrapping GNU Stow."""

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import urllib.request
from pathlib import Path

DOTFILES_DIR = Path(__file__).resolve().parent.parent
STOW_DIR = DOTFILES_DIR / "stow"
TARGET_DIR = Path.home()


def stow_force_overwrite(pkg: str) -> int:
    """Force-install a package by backing up and removing conflicting files, then stowing."""
    # stow may not report all conflicts in a single --simulate pass, so loop
    # until simulate is clean, removing conflicts each round.
    # stow emits two different formats depending on version/conflict type:
    #   old: "existing target is neither a link nor a directory: .config/..."
    #   new: "cannot stow ... over existing target .config/... since neither ..."
    backup_dir: Path | None = None

    for _ in range(100):  # hard cap to prevent infinite loops
        sim = run_stow(["--simulate", "-S", pkg], capture=True)
        if sim.returncode == 0:
            break

        conflicts: list[Path] = []
        for line in sim.stderr.splitlines():
            m = re.search(r"existing target[^:]*:\s+(.+)$", line)
            if not m:
                m = re.search(r"over existing target\s+(.+?)\s+since\b", line)
            if m:
                conflicts.append(TARGET_DIR / m.group(1).strip())

        if not conflicts:
            # Unexpected failure — just try anyway
            return run_stow(["-S", pkg]).returncode

        if backup_dir is None:
            backup_dir = Path(tempfile.mkdtemp(prefix=f"dots-overwrite-{pkg}-"))

        for conflict in conflicts:
            rel = conflict.relative_to(TARGET_DIR)
            dest = backup_dir / rel
            dest.parent.mkdir(parents=True, exist_ok=True)
            if conflict.is_symlink() or conflict.is_file():
                shutil.copy2(conflict, dest)
                conflict.unlink()
            elif conflict.is_dir():
                shutil.copytree(conflict, dest)
                shutil.rmtree(conflict)

    if backup_dir:
        print(f"  Backup of overwritten files: {backup_dir}")

    return run_stow(["-S", pkg]).returncode


def run_stow(args: list[str], capture: bool = False) -> subprocess.CompletedProcess:
    cmd = ["stow", "-d", str(STOW_DIR), "-t", str(TARGET_DIR)] + args
    return subprocess.run(cmd, cwd=DOTFILES_DIR, capture_output=capture, text=True)


def get_stowed_packages() -> dict[str, list[Path]]:
    """Scan TARGET_DIR for symlinks pointing into STOW_DIR, grouped by package."""
    stow_resolved = STOW_DIR.resolve()
    packages: dict[str, list[Path]] = {}

    for pkg_dir in sorted(STOW_DIR.iterdir()):
        if not pkg_dir.is_dir():
            continue
        pkg_name = pkg_dir.name
        pkg_prefix = str(stow_resolved / pkg_name)
        links: list[Path] = []

        for root, dirs, files in os.walk(pkg_dir):
            for name in list(dirs) + files:
                stow_entry = Path(root) / name
                rel = stow_entry.relative_to(pkg_dir)
                target_entry = TARGET_DIR / rel
                if target_entry.is_symlink():
                    try:
                        # Use readlink (one level) to handle symlinks-of-symlinks
                        # e.g. ~/.config/starship.toml -> stow/starship/.config/starship.toml
                        # even if that file itself is a symlink to misc/...
                        link_target = target_entry.parent / os.readlink(target_entry)
                        resolved = link_target.resolve()
                        stow_entry_resolved = stow_entry.resolve()
                        if (
                            str(resolved).startswith(pkg_prefix)
                            or resolved == stow_entry_resolved
                        ):
                            links.append(target_entry)
                            # If a directory is a symlink (tree folding),
                            # don't descend into it on the target side
                            if name in dirs:
                                dirs.remove(name)
                    except OSError:
                        pass
        if links:
            packages[pkg_name] = links

    return packages


def has_conflicts(pkg: str) -> bool:
    """Dry-run stow to check for conflicts."""
    result = run_stow(["--simulate", "-S", pkg], capture=True)
    return result.returncode != 0


def _confirm(prompt: str) -> bool:
    try:
        return input(prompt).strip().lower() in ("y", "yes")
    except (EOFError, KeyboardInterrupt):
        print()
        return False


def post_install(pkg: str) -> None:
    """Run post-install hooks for specific packages."""
    if pkg == "zsh":
        zprezto = Path.home() / ".zprezto"
        if not zprezto.exists():
            if not shutil.which("git"):
                print("  Prezto: skipped (git not found)")
            elif _confirm("  Install Prezto? [y/N] "):
                print("  Installing Prezto...")
                subprocess.run(
                    [
                        "git",
                        "clone",
                        "--recursive",
                        "https://github.com/sorin-ionescu/prezto.git",
                        str(zprezto),
                    ],
                )
            else:
                print("  Prezto: skipped")
        else:
            print("  Prezto: already installed")
    elif pkg == "shell":
        plugins_dir = (
            Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config")))
            / "nnn"
            / "plugins"
        )
        if not (plugins_dir / "preview-tui").exists():
            if not shutil.which("curl"):
                print("  nnn plugins: skipped (curl not found)")
            elif _confirm("  Install nnn plugins? [y/N] "):
                print("  Installing nnn plugins...")
                subprocess.run(
                    [
                        "sh",
                        "-c",
                        "curl -Ls https://raw.githubusercontent.com/jarun/nnn/master/plugins/getplugs | sh",
                    ],
                )
            else:
                print("  nnn plugins: skipped")
        else:
            print("  nnn plugins: already installed")


def cmd_install(args: argparse.Namespace) -> int:
    for pkg in args.packages:
        pkg_path = STOW_DIR / pkg
        if not pkg_path.is_dir():
            print(f"Error: package '{pkg}' not found in {STOW_DIR}", file=sys.stderr)
            return 1

        if args.copy:
            count = copy_install(pkg)
            print(f"Installed (copied): {pkg} ({count} files)")
            post_install(pkg)
            continue

        conflicts = has_conflicts(pkg)

        if not conflicts:
            result = run_stow(["-S", pkg])
            if result.returncode == 0:
                print(f"Installed: {pkg}")
                post_install(pkg)
            else:
                print(f"Failed to install: {pkg}", file=sys.stderr)
                return result.returncode
            continue

        if args.overwrite:
            rc = stow_force_overwrite(pkg)
            if rc != 0:
                print(f"Failed to install: {pkg}", file=sys.stderr)
                return rc
            print(f"Installed (overwritten): {pkg}")
            post_install(pkg)
        elif args.adopt:
            result = run_stow(["--adopt", "-S", pkg])
            if result.returncode == 0:
                print(f"Installed (adopted existing files): {pkg}")
                post_install(pkg)
            else:
                print(f"Failed to adopt: {pkg}", file=sys.stderr)
                return result.returncode
        else:
            print(f"Conflicts detected for '{pkg}'.")
            print("  [a]dopt existing files into dotfiles")
            print("  [o]verwrite with dotfiles versions")
            print("  [c]opy dotfiles versions in (real files, no symlinks)")
            print("  [s]kip")
            choice = input("  Choice [a/o/c/s]: ").strip().lower()
            if choice == "a":
                result = run_stow(["--adopt", "-S", pkg])
                if result.returncode == 0:
                    print(f"Installed (adopted): {pkg}")
                    post_install(pkg)
                else:
                    return result.returncode
            elif choice == "o":
                rc = stow_force_overwrite(pkg)
                if rc != 0:
                    return rc
                print(f"Installed (overwritten): {pkg}")
                post_install(pkg)
            elif choice == "c":
                count = copy_install(pkg)
                print(f"Installed (copied): {pkg} ({count} files)")
                post_install(pkg)
            else:
                print(f"Skipped: {pkg}")

    return 0


def cmd_remove(args: argparse.Namespace) -> int:
    stowed = get_stowed_packages()

    for pkg in args.packages:
        pkg_path = STOW_DIR / pkg
        if not pkg_path.is_dir():
            print(f"Error: package '{pkg}' not found in {STOW_DIR}", file=sys.stderr)
            return 1

        if pkg not in stowed:
            print(f"Package '{pkg}' is not currently stowed, skipping.")
            continue

        # Replace symlinks with copies of the actual files
        for symlink in stowed[pkg]:
            target = symlink.resolve()
            if target.is_file():
                symlink.unlink()
                shutil.copy2(target, symlink)
            elif target.is_dir():
                symlink.unlink()
                shutil.copytree(target, symlink)

        # Run stow -D to clean up any remaining state
        run_stow(["-D", pkg])
        print(f"Removed: {pkg} (files copied back to {TARGET_DIR})")

    return 0


def get_package_drift(
    pkg: str, stowed_links: list[Path]
) -> tuple[list[Path], list[Path]]:
    """Return (repo_only, unmanaged) for a package.

    repo_only:  files in the stow package that have no counterpart in TARGET_DIR.
    unmanaged:  real files (or foreign symlinks) in TARGET_DIR at paths the package owns.
    """
    pkg_dir = STOW_DIR / pkg
    stow_pkg_prefix = str((STOW_DIR / pkg).resolve())
    stowed_set = {str(p) for p in stowed_links}
    repo_only: list[Path] = []
    unmanaged: list[Path] = []

    for root, _dirs, files in os.walk(pkg_dir):
        for name in files:
            rel = (Path(root) / name).relative_to(pkg_dir)
            target = TARGET_DIR / rel

            # Check if this target or any ancestor directory is already stow-managed
            # (handles folder-folding where stow symlinks a whole directory).
            is_stowed = False
            check = target
            while check != TARGET_DIR and check != check.parent:
                if str(check) in stowed_set:
                    is_stowed = True
                    break
                check = check.parent
            if is_stowed:
                continue

            if target.is_symlink():
                try:
                    if not str(target.resolve()).startswith(stow_pkg_prefix):
                        unmanaged.append(target)
                except OSError:
                    repo_only.append(target)  # broken symlink
            elif target.exists():
                unmanaged.append(target)
            else:
                repo_only.append(target)

    return repo_only, unmanaged


def cmd_list(args: argparse.Namespace) -> int:
    stowed = get_stowed_packages()
    all_pkgs = sorted(d.name for d in STOW_DIR.iterdir() if d.is_dir())
    if not all_pkgs:
        print("No packages available.")
        return 0

    for pkg in all_pkgs:
        stowed_links = stowed.get(pkg, [])
        repo_only, unmanaged = get_package_drift(pkg, stowed_links)

        if args.installed and not stowed_links:
            continue
        if args.not_installed and not repo_only:
            continue
        if args.unmanaged and not unmanaged:
            continue

        parts = [f"{len(stowed_links)} stowed"]
        if repo_only:
            parts.append(f"{len(repo_only)} not linked")
        if unmanaged:
            parts.append(f"{len(unmanaged)} unmanaged")
        print(f"{pkg} ({', '.join(parts)})")

    return 0


def _find_broken_symlinks(root: Path) -> list[Path]:
    """Return broken symlinks under root (or root itself, if broken)."""
    broken: list[Path] = []
    if root.is_symlink():
        if not root.exists():
            broken.append(root)
        return broken
    if not root.is_dir():
        return broken
    for dirpath, dirnames, filenames in os.walk(root, followlinks=False):
        for name in dirnames + filenames:
            p = Path(dirpath) / name
            if p.is_symlink() and not p.exists():
                broken.append(p)
    return broken


def _classify_file(src: Path, dest: Path, new: list, changed: list, unchanged: list) -> None:
    if not dest.exists():
        new.append(dest)
        return
    try:
        if src.read_bytes() == dest.read_bytes():
            unchanged.append(dest)
        else:
            changed.append(dest)
    except OSError:
        changed.append(dest)


def _plan_merge(src: Path, dest: Path, pkg_resolved: Path) -> tuple[list[Path], list[Path], list[Path]]:
    """Walk src and classify what _merge_copy would do — returns (new, changed, unchanged)."""
    new: list[Path] = []
    changed: list[Path] = []
    unchanged: list[Path] = []

    def visit(s: Path, d: Path) -> None:
        if s.is_symlink():
            try:
                real = s.resolve(strict=True)
            except (FileNotFoundError, OSError):
                return
            try:
                real.relative_to(pkg_resolved)
                return
            except ValueError:
                pass
            if real.is_dir():
                for entry in real.iterdir():
                    visit(entry, d / entry.name)
            else:
                _classify_file(real, d, new, changed, unchanged)
            return
        if s.is_dir():
            for entry in s.iterdir():
                visit(entry, d / entry.name)
        elif s.is_file():
            _classify_file(s, d, new, changed, unchanged)

    visit(src, dest)
    return new, changed, unchanged


def _merge_copy(src: Path, dest: Path, pkg_resolved: Path) -> None:
    """Copy src to dest, merging into existing dest tree and dereferencing symlinks.

    Symlinks that already point inside pkg_resolved are skipped (already adopted).
    Broken symlinks are silently skipped (callers should clean them first).
    """
    if src.is_symlink():
        try:
            real = src.resolve(strict=True)
        except (FileNotFoundError, OSError):
            return
        try:
            real.relative_to(pkg_resolved)
            return
        except ValueError:
            pass
        if real.is_dir():
            dest.mkdir(parents=True, exist_ok=True)
            for entry in real.iterdir():
                _merge_copy(entry, dest / entry.name, pkg_resolved)
        else:
            dest.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(real, dest, follow_symlinks=True)
        return
    if src.is_dir():
        dest.mkdir(parents=True, exist_ok=True)
        for entry in src.iterdir():
            _merge_copy(entry, dest / entry.name, pkg_resolved)
    elif src.is_file():
        dest.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dest, follow_symlinks=True)


def _place_file(real_src: Path, dest: Path) -> int:
    """Write real_src to dest as an independent file, replacing whatever is there."""
    if dest.is_symlink() or dest.exists():
        if dest.is_dir() and not dest.is_symlink():
            shutil.rmtree(dest)
        else:
            dest.unlink()
    dest.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(real_src, dest, follow_symlinks=True)
    return 1


def _copy_install_tree(src: Path, dest: Path) -> int:
    """Copy src→dest as real files, dereferencing symlinks and replacing any
    existing dest (symlink or file) with an independent copy. Returns file count.

    Unlike stowing, this leaves no symlinks behind — useful for apps that save
    config via atomic rename (e.g. COSMIC), which would clobber a stow symlink.
    """
    if src.is_symlink():
        try:
            real = src.resolve(strict=True)
        except OSError:
            return 0  # broken symlink in the package — skip
        if real.is_dir():
            count = 0
            if dest.is_symlink() or (dest.exists() and not dest.is_dir()):
                dest.unlink()
            dest.mkdir(parents=True, exist_ok=True)
            for entry in real.iterdir():
                count += _copy_install_tree(entry, dest / entry.name)
            return count
        return _place_file(real, dest)
    if src.is_dir():
        count = 0
        if dest.is_symlink() or (dest.exists() and not dest.is_dir()):
            dest.unlink()
        dest.mkdir(parents=True, exist_ok=True)
        for entry in src.iterdir():
            count += _copy_install_tree(entry, dest / entry.name)
        return count
    if src.is_file():
        return _place_file(src, dest)
    return 0


def copy_install(pkg: str) -> int:
    """Install a package by copying real files into the target (no symlinks)."""
    pkg_path = STOW_DIR / pkg
    return _copy_install_tree(pkg_path, TARGET_DIR)


def cmd_adopt(args: argparse.Namespace) -> int:
    pkg_path = STOW_DIR / args.package
    dry = getattr(args, "dry_run", False)

    if pkg_path.exists() and args.overwrite:
        if dry:
            print(f"  Would rmtree: {pkg_path}")
        else:
            shutil.rmtree(pkg_path)

    if not dry:
        pkg_path.mkdir(parents=True, exist_ok=True)
    pkg_resolved = pkg_path.resolve() if pkg_path.exists() else (STOW_DIR.resolve() / args.package)

    total_broken: list[Path] = []
    total_new: list[Path] = []
    total_changed: list[Path] = []
    total_unchanged: list[Path] = []

    for file_path in args.files:
        src = Path(file_path).expanduser().absolute()
        if not (src.exists() or src.is_symlink()):
            print(f"Warning: '{file_path}' does not exist, skipping.", file=sys.stderr)
            continue

        try:
            rel = src.relative_to(TARGET_DIR)
        except ValueError:
            print(
                f"Warning: '{file_path}' is not under {TARGET_DIR}, skipping.",
                file=sys.stderr,
            )
            continue

        broken = _find_broken_symlinks(src)
        total_broken.extend(broken)
        for p in broken:
            if dry:
                print(f"  Would remove broken symlink: {p}")
            else:
                p.unlink()
                print(f"  Removed broken symlink: {p}")

        dest = pkg_path / rel

        if dry:
            new, changed, unchanged = _plan_merge(src, dest, pkg_resolved)
            total_new.extend(new)
            total_changed.extend(changed)
            total_unchanged.extend(unchanged)
            for p in new:
                print(f"  Would add:       {p.relative_to(STOW_DIR)}")
            for p in changed:
                print(f"  Would overwrite: {p.relative_to(STOW_DIR)}")
        else:
            _merge_copy(src, dest, pkg_resolved)
            print(f"  Adopted: {rel}")

    if dry:
        print(
            f"\nDry-run summary for '{args.package}': "
            f"{len(total_broken)} broken symlink(s) to remove, "
            f"{len(total_new)} file(s) to add, "
            f"{len(total_changed)} file(s) to overwrite, "
            f"{len(total_unchanged)} unchanged."
        )
        print("Re-run without --dry-run to apply.")
        return 0

    if args.copy:
        # Copy-managed package: the live files already are the installed copies,
        # so there is nothing to re-stow (mirror of `dots install --copy`, reversed).
        print(f"Adopted (copied) package: {args.package}")
        return 0

    print(f"Adopted package: {args.package}")

    # Decide whether to install
    if args.install:
        do_install = True
    elif args.no_install:
        do_install = False
    else:
        choice = input("Install this package now? [y/N]: ").strip().lower()
        do_install = choice in ("y", "yes")

    if do_install:
        # Re-stow cleanly: unstow first (ignore failure if not currently stowed),
        # then re-stow with --adopt to absorb any straggling real files.
        run_stow(["-D", args.package], capture=True)
        result = run_stow(["--adopt", "-S", args.package])
        if result.returncode == 0:
            print(f"Installed: {args.package}")
        else:
            print(f"Failed to install: {args.package}", file=sys.stderr)
            return result.returncode

    return 0


def cmd_update(args: argparse.Namespace) -> int:
    branch_res = subprocess.run(
        ["git", "-C", str(DOTFILES_DIR), "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True,
        text=True,
    )
    if branch_res.returncode != 0:
        print("Error: could not determine git branch", file=sys.stderr)
        return 1
    branch = branch_res.stdout.strip()

    dirty_res = subprocess.run(
        ["git", "-C", str(DOTFILES_DIR), "status", "--porcelain"],
        capture_output=True,
        text=True,
    )
    is_dirty = bool(dirty_res.stdout.strip())

    if branch != "main" or is_dirty:
        if branch != "main":
            print(f"Warning: not on main branch (current: {branch})", file=sys.stderr)
        if is_dirty:
            print("Warning: repository has uncommitted changes", file=sys.stderr)
            for line in dirty_res.stdout.splitlines():
                print(f"  {line}", file=sys.stderr)
        return 1

    result = subprocess.run(["git", "-C", str(DOTFILES_DIR), "pull"])
    return result.returncode


def cmd_edit(args: argparse.Namespace) -> int:
    pkg_path = STOW_DIR / args.package
    if not pkg_path.is_dir():
        print(
            f"Error: package '{args.package}' not found in {STOW_DIR}", file=sys.stderr
        )
        return 1

    editor = os.environ.get("EDITOR", "vi")
    return subprocess.run([editor, str(pkg_path)], cwd=pkg_path).returncode


def cmd_dir(args: argparse.Namespace) -> int:
    if args.package:
        pkg_path = STOW_DIR / args.package
        if not pkg_path.is_dir():
            print(
                f"Error: package '{args.package}' not found in {STOW_DIR}",
                file=sys.stderr,
            )
            return 1
        print(pkg_path)
    else:
        print(DOTFILES_DIR)
    return 0


def cmd_checkhealth(args: argparse.Namespace) -> int:
    use_color = sys.stdout.isatty()
    if use_color:
        G = "\033[32m"
        Y = "\033[33m"
        R = "\033[31m"
        C = "\033[36m"
        B = "\033[1m"
        X = "\033[0m"
    else:
        G = Y = R = C = B = X = ""

    def ok(msg: str) -> None:
        print(f"  {G}OK{X}    {msg}")

    def warn(msg: str) -> None:
        print(f"  {Y}WARN{X}  {msg}")

    def err(msg: str) -> None:
        print(f"  {R}ERROR{X} {msg}")

    def section(title: str) -> None:
        print(f"\n{B}{C}## {title}{X}")

    # ── dots & stow ──────────────────────────────────────────────────────────
    section("dots & stow")
    dots_path = shutil.which("dots")
    if dots_path:
        ok(f"dots: {dots_path}")
    else:
        err("dots not on PATH — symlink scripts/dots into ~/.local/bin")
    stow_path = shutil.which("stow")
    if stow_path:
        ok(f"stow: {stow_path}")
    else:
        err("stow not installed  (run: pixi global install --expose stow stow)")

    # ── Shell ────────────────────────────────────────────────────────────────
    section("Shell")
    shell = os.environ.get("SHELL", "")
    if not shell:
        try:
            pw = subprocess.run(
                ["getent", "passwd", os.environ.get("USER", "")],
                capture_output=True,
                text=True,
                timeout=5,
            )
            if pw.returncode == 0:
                shell = pw.stdout.strip().rsplit(":", 1)[-1]
        except Exception:
            pass
    if shell:
        ok(f"Default shell: {shell}")
    else:
        warn("Could not determine default shell")

    stowed_early = get_stowed_packages()
    shell_stowed = "shell" in stowed_early and stowed_early["shell"]
    bash_stowed = "bash" in stowed_early and stowed_early["bash"]
    zsh_stowed = "zsh" in stowed_early and stowed_early["zsh"]
    if shell_stowed:
        ok("shell dotfiles: stowed")
    else:
        warn("shell dotfiles: not stowed")
    if "zsh" in shell:
        if zsh_stowed:
            ok("zsh dotfiles: stowed")
        else:
            warn("zsh dotfiles: not stowed (run: dots install zsh)")
    elif "bash" in shell:
        if bash_stowed:
            ok("bash dotfiles: stowed")
        else:
            warn("bash dotfiles: not stowed (run: dots install bash)")
    if bash_stowed and not shell_stowed:
        warn("bash dotfiles stowed but shell package is not (run: dots install shell)")
    if zsh_stowed and not shell_stowed:
        warn("zsh dotfiles stowed but shell package is not (run: dots install shell)")

    # ── Prezto ───────────────────────────────────────────────────────────────
    section("Prezto")
    zprezto = Path.home() / ".zprezto"
    if not zprezto.exists():
        err("Prezto not installed (run: dots install zsh)")
    else:
        ok(f"Installed at {zprezto}")
        if not (zprezto / ".git").exists():
            warn("Not a git repo — cannot check for updates")
        else:
            try:
                local = subprocess.run(
                    ["git", "-C", str(zprezto), "rev-parse", "HEAD"],
                    capture_output=True,
                    text=True,
                    timeout=5,
                ).stdout.strip()
                remote_res = subprocess.run(
                    ["git", "-C", str(zprezto), "ls-remote", "origin", "HEAD"],
                    capture_output=True,
                    text=True,
                    timeout=15,
                )
                if remote_res.returncode == 0 and remote_res.stdout.strip():
                    remote = remote_res.stdout.split()[0]
                    if local == remote:
                        ok(f"Up to date ({local[:8]})")
                    else:
                        warn(
                            f"Updates available  local:{local[:8]} → remote:{remote[:8]}"
                        )
                        warn(
                            "Update: git -C ~/.zprezto pull && git -C ~/.zprezto submodule update --init --recursive"
                        )
                else:
                    warn("Could not reach Prezto remote (offline?)")
            except subprocess.TimeoutExpired:
                warn("Timed out checking Prezto remote")

    # ── Pixi ─────────────────────────────────────────────────────────────────
    section("Pixi")
    pixi_path = shutil.which("pixi")
    if not pixi_path:
        warn("pixi not installed")
        warn("Install: curl -fsSL https://pixi.sh/install.sh | bash")
    else:
        ok(f"Installed at {pixi_path}")
        ver_res = subprocess.run(
            ["pixi", "--version"], capture_output=True, text=True, timeout=5
        )
        current_ver = ver_res.stdout.strip() if ver_res.returncode == 0 else ""
        if current_ver:
            ok(f"Version: {current_ver}")
        try:
            req = urllib.request.Request(
                "https://api.github.com/repos/prefix-dev/pixi/releases/latest",
                headers={"User-Agent": "dots-checkhealth/1.0"},
            )
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read())
            latest_tag = data.get("tag_name", "").lstrip("v")
            current_tag = (
                current_ver.removeprefix("pixi ").strip() if current_ver else ""
            )
            if latest_tag and current_tag:
                if current_tag == latest_tag:
                    ok(f"Up to date (v{latest_tag})")
                else:
                    warn(
                        f"Update available: v{current_tag} → v{latest_tag}  (run: pixi self-update)"
                    )
            else:
                warn("Could not compare pixi versions")
        except Exception as exc:
            warn(f"Could not check for pixi updates: {exc}")

    # ── Recommended Programs ─────────────────────────────────────────────────
    section("Recommended Programs")
    # (display_name, [binary_candidates], stow_package_or_None)
    TOOLS: list[tuple[str, list[str], str | None]] = [
        ("bat", ["bat", "batcat"], "bat"),
        ("carapace", ["carapace"], None),
        ("cargo", ["cargo"], None),
        ("delta", ["delta"], None),
        ("fd", ["fd"], None),
        ("fzf", ["fzf"], None),
        ("git", ["git"], "git"),
        ("nnn", ["nnn"], None),
        ("nvim", ["nvim"], "nvim"),
        ("pixi", ["pixi"], None),
        ("ripgrep", ["rg"], None),
        ("starship", ["starship"], "starship"),
        ("tmux", ["tmux"], "tmux"),
        ("wezterm", ["wezterm"], "wezterm"),
        ("zoxide", ["zoxide"], None),
        ("zsh", ["zsh"], "zsh"),
    ]
    stowed = get_stowed_packages()
    for display, candidates, pkg in TOOLS:
        found_cmd = found_path = None
        for candidate in candidates:
            p = shutil.which(candidate)
            if p:
                found_cmd, found_path = candidate, p
                break
        # Determine dotfiles status
        dots_status = None  # None = no stow package for this tool
        if pkg:
            pkg_dir = STOW_DIR / pkg
            if pkg_dir.is_dir():
                dots_status = (
                    "stowed" if (pkg in stowed and stowed[pkg]) else "not stowed"
                )
            else:
                dots_status = "none"

        # Warn if installed but dotfiles available and not stowed
        if found_path and dots_status == "not stowed":
            warn(display)
        elif found_path:
            ok(display)
        else:
            warn(display)

        if found_path:
            suffix = f" (as {found_cmd})" if found_cmd != candidates[0] else ""
            print(f"          binary: {found_path}{suffix}")
        else:
            print(f"          binary: not found")
        if dots_status is not None:
            print(f"          dotfiles: {dots_status}")
        # nnn addon check
        if display == "nnn" and found_path:
            nnn_preview = (
                Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config")))
                / "nnn"
                / "plugins"
                / "preview-tui"
            )
            if nnn_preview.exists():
                print(f"          plugins: installed")
            else:
                print(f"          plugins: not installed (run: dots install shell)")

    # ── Nerd Fonts ───────────────────────────────────────────────────────────
    section("Nerd Fonts")
    nerd_families: set[str] = set()
    if shutil.which("fc-list"):
        try:
            fc_res = subprocess.run(
                ["fc-list", ":", "family"],
                capture_output=True,
                text=True,
                timeout=10,
            )
            for line in fc_res.stdout.splitlines():
                for token in line.split(","):
                    token = token.strip()
                    if "nerd" in token.lower():
                        nerd_families.add(token)
        except Exception:
            pass
    else:
        # Fallback: scan common font dirs for files with "nerd" in the name
        font_dirs = [
            Path.home() / ".local/share/fonts",
            Path.home() / ".fonts",
            Path("/usr/share/fonts"),
            Path("/usr/local/share/fonts"),
        ]
        for font_dir in font_dirs:
            if font_dir.is_dir():
                for f in font_dir.rglob("*"):
                    if (
                        f.suffix.lower() in (".ttf", ".otf")
                        and "nerd" in f.stem.lower()
                    ):
                        nerd_families.add(f.stem)

    if nerd_families:
        for fam in sorted(nerd_families):
            ok(fam)
    else:
        warn("No Nerd Fonts detected")
        warn(
            "Required by many configs — install from: https://www.nerdfonts.com/font-downloads"
        )

    print()
    return 0


def cmd_deploy(args: argparse.Namespace) -> int:
    host = args.host
    remote_dotfiles = "~/.dotfiles"

    # Check if .dotfiles already exists on the remote
    result = subprocess.run(
        ["ssh", "-o", "ConnectTimeout=5", host, f"test -d {remote_dotfiles}"],
        capture_output=True,
    )
    if result.returncode == 255:
        print(f"Error: could not connect to {host}", file=sys.stderr)
        return 1
    if result.returncode == 0:
        print(f"Error: {remote_dotfiles} already exists on {host}", file=sys.stderr)
        print(
            f"  Delete it first:  ssh {host} rm -rf {remote_dotfiles}", file=sys.stderr
        )
        return 1

    # Archive working tree (including local changes, excluding .git)
    print(f"Copying dotfiles to {host}:{remote_dotfiles} ...")
    archive = subprocess.run(
        ["tar", "czf", "-", "--exclude=.git", "-C", str(DOTFILES_DIR), "."],
        capture_output=True,
    )
    if archive.returncode != 0:
        print("Error: tar archive failed", file=sys.stderr)
        return 1
    extract = subprocess.run(
        ["ssh", host, f"mkdir -p {remote_dotfiles} && tar xzf - -C {remote_dotfiles}"],
        input=archive.stdout,
    )
    if extract.returncode != 0:
        print("Error: remote extract failed", file=sys.stderr)
        return 1
    print("Done.")

    # Bootstrap
    if args.bootstrap is None:
        try:
            answer = input(f"Run bootstrap.sh on {host}? [y/N] ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            answer = "n"
        run_bootstrap = answer in ("y", "yes")
    else:
        run_bootstrap = args.bootstrap

    if run_bootstrap:
        print(f"Running bootstrap.sh on {host} ...")
        subprocess.run(["ssh", "-t", host, f"{remote_dotfiles}/bootstrap.sh"])

    return 0


def cmd_completion(args: argparse.Namespace) -> int:
    shell = args.shell
    stow_dir = str(STOW_DIR)

    if shell == "zsh":
        print(f"""\
# dots zsh completion — generated by: dots completion zsh
_dots() {{
    local state
    local -a subcommands
    subcommands=(
        'install:Install (stow) packages'
        'remove:Remove (unstow) packages'
        'list:List packages and their stow status'
        'adopt:Create a new stow package from existing files'
        'update:Pull latest changes (main branch only, clean repo)'
        'dir:Print path to dotfiles or package dir'
        'edit:Open a package directory in $EDITOR'
        'deploy:Deploy dotfiles to a remote host'
        'checkhealth:Check dotfiles environment health'
        'completion:Print shell completion script'
    )
    local -a packages
    packages=(${{(f)"$(ls -1 '{stow_dir}' 2>/dev/null)"}})
    _arguments -C \\
        '1:command:->command' \\
        '*::args:->args'
    case $state in
        command)
            _describe 'command' subcommands
            ;;
        args)
            case $words[1] in
                install)
                    _arguments \\
                        '(-o --overwrite -a --adopt -c --copy)'{{-o,--overwrite}}'[overwrite existing files]' \\
                        '(-o --overwrite -a --adopt -c --copy)'{{-a,--adopt}}'[adopt existing files into dotfiles]' \\
                        '(-o --overwrite -a --adopt -c --copy)'{{-c,--copy}}'[copy files instead of symlinking]' \\
                        '*:package:(${{packages[@]}})'
                    ;;
                remove|edit)
                    _arguments '*:package:(${{packages[@]}})'
                    ;;
                dir)
                    _arguments '::package:(${{packages[@]}})'
                    ;;
                list)
                    _arguments \\
                        '--installed[only show installed packages]' \\
                        '--not-installed[only show packages with unlinked files]' \\
                        '--unmanaged[only show packages with unmanaged files in dest]'
                    ;;
                adopt)
                    _arguments \\
                        '(-o --overwrite)'{{-o,--overwrite}}'[overwrite existing package]' \\
                        '(-i --install -n --no-install -c --copy)'{{-i,--install}}'[install after creating]' \\
                        '(-i --install -n --no-install -c --copy)'{{-n,--no-install}}'[don'"'"'t install after creating]' \\
                        '(-i --install -n --no-install -c --copy)'{{-c,--copy}}'[copy-managed package: real files, no re-stow]' \\
                        '1:package' \\
                        '*:file:_files'
                    ;;
                deploy)
                    _arguments \\
                        '--bootstrap[run bootstrap.sh on remote after copying]' \\
                        '--no-bootstrap[skip bootstrap.sh on remote]' \\
                        '1:host:_hosts'
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh)'
                    ;;
            esac
            ;;
    esac
}}
compdef _dots dots""")

    elif shell == "bash":
        print(f"""\
# dots bash completion — generated by: dots completion bash
_dots_bash() {{
    local cur prev words cword
    _init_completion 2>/dev/null || {{
        cur="${{COMP_WORDS[COMP_CWORD]}}"
        words=("${{COMP_WORDS[@]}}")
        cword=$COMP_CWORD
    }}
    local subcommands="install remove list adopt update dir edit deploy checkhealth completion"
    local packages
    packages=$(ls -1 '{stow_dir}' 2>/dev/null | tr '\\n' ' ')
    if [ "$cword" -eq 1 ]; then
        COMPREPLY=($(compgen -W "$subcommands" -- "$cur"))
        return
    fi
    local subcmd="${{words[1]}}"
    case $subcmd in
        install)
            case $cur in
                -*) COMPREPLY=($(compgen -W "-o --overwrite -a --adopt -c --copy" -- "$cur")) ;;
                *)  COMPREPLY=($(compgen -W "$packages" -- "$cur")) ;;
            esac ;;
        remove|edit)
            COMPREPLY=($(compgen -W "$packages" -- "$cur")) ;;
        dir)
            [ "$cword" -eq 2 ] && COMPREPLY=($(compgen -W "$packages" -- "$cur")) ;;
        list)
            COMPREPLY=($(compgen -W "--installed --not-installed --unmanaged" -- "$cur")) ;;
        adopt)
            if [ "$cword" -eq 2 ]; then
                case $cur in
                    -*) COMPREPLY=($(compgen -W "-o --overwrite -i --install -n --no-install -c --copy" -- "$cur")) ;;
                esac
            else
                COMPREPLY=($(compgen -f -- "$cur"))
            fi ;;
        deploy)
            case $cur in
                -*) COMPREPLY=($(compgen -W "--bootstrap --no-bootstrap" -- "$cur")) ;;
                *)  COMPREPLY=($(compgen -A hostname -- "$cur")) ;;
            esac ;;
        completion)
            [ "$cword" -eq 2 ] && COMPREPLY=($(compgen -W "bash zsh" -- "$cur")) ;;
    esac
}}
complete -F _dots_bash dots""")

    else:
        print(f"Error: unsupported shell '{shell}'. Choose bash or zsh.", file=sys.stderr)
        return 1

    return 0


def check_stow() -> None:
    if shutil.which("stow") is None:
        print("Error: GNU Stow is not installed.", file=sys.stderr)
        print("  Install with: pixi global install --expose stow stow", file=sys.stderr)
        sys.exit(1)


def main() -> int:

    fmt = argparse.RawDescriptionHelpFormatter

    parser = argparse.ArgumentParser(
        prog="dots",
        description=(
            "Unified dotfiles management built on GNU Stow.\n"
            "\n"
            "Each subdirectory of stow/ is a 'package' whose contents are symlinked\n"
            "into your home directory. `dots` wraps stow with conflict handling,\n"
            "status listings, and helpers for capturing live config files back into\n"
            "the repo."
        ),
        epilog=(
            "Common workflows:\n"
            "  dots list                          # see which packages are installed\n"
            "  dots install zsh nvim              # symlink package files into ~\n"
            "  dots adopt cosmic ~/.config/cosmic # capture live state into stow/cosmic\n"
            "  dots edit zsh                      # open a package in $EDITOR\n"
        ),
        formatter_class=fmt,
    )
    sub = parser.add_subparsers(dest="command", metavar="<command>")

    # install
    p_install = sub.add_parser(
        "install",
        help="Symlink package files into your home directory",
        description=(
            "Install one or more packages by creating symlinks from your home\n"
            "directory into stow/<package>/. If a target path already exists with\n"
            "different content, dots prompts you to adopt (move the existing file\n"
            "into the package), overwrite (replace with the package's version,\n"
            "saving a timestamped backup), or skip."
        ),
        epilog=(
            "Examples:\n"
            "  dots install zsh                # interactive on conflicts\n"
            "  dots install -o cosmic          # force overwrite existing files\n"
            "  dots install -a nvim            # adopt existing files into the package\n"
            "  dots install -c cosmic          # copy files instead of symlinking\n"
            "  dots install zsh nvim shell     # install multiple at once\n"
        ),
        formatter_class=fmt,
    )
    p_install.add_argument("packages", nargs="+", help="Package names to install")
    conflict_group = p_install.add_mutually_exclusive_group()
    conflict_group.add_argument(
        "-o",
        "--overwrite",
        action="store_true",
        help="On conflict, replace target with the package version (backs up the original)",
    )
    conflict_group.add_argument(
        "-a",
        "--adopt",
        action="store_true",
        help="On conflict, move the existing file into the package and symlink it",
    )
    conflict_group.add_argument(
        "-c",
        "--copy",
        action="store_true",
        help="Copy real files into the target instead of symlinking (overwrites existing); "
        "for apps that save via atomic rename and would clobber stow symlinks (e.g. COSMIC)",
    )
    p_install.set_defaults(func=cmd_install)

    # remove
    p_remove = sub.add_parser(
        "remove",
        help="Remove symlinks created by a package (unstow)",
        description=(
            "Remove the symlinks a package created in your home directory. The\n"
            "files in stow/<package>/ are NOT deleted — use this to temporarily\n"
            "uninstall a package without losing its content."
        ),
        epilog="Example:\n  dots remove zsh\n",
        formatter_class=fmt,
    )
    p_remove.add_argument("packages", nargs="+", help="Package names to remove")
    p_remove.set_defaults(func=cmd_remove)

    # list
    p_list = sub.add_parser(
        "list",
        help="Show packages and their install status",
        description=(
            "List every package under stow/ along with one of three statuses:\n"
            "  installed     — all files are symlinked into the destination\n"
            "  not installed — package exists but no symlinks present\n"
            "  partial       — some files linked, others missing or conflicting\n"
            "Filters narrow the output to a specific category."
        ),
        epilog=(
            "Examples:\n"
            "  dots list                  # everything\n"
            "  dots list --installed      # only fully-installed packages\n"
            "  dots list --not-installed  # packages with at least one unlinked file\n"
            "  dots list --unmanaged      # packages with conflicting files in dest\n"
        ),
        formatter_class=fmt,
    )
    p_list.add_argument(
        "--installed",
        action="store_true",
        help="Only show packages with at least one stowed file",
    )
    p_list.add_argument(
        "--not-installed",
        action="store_true",
        help="Only show packages with at least one file not linked in dest",
    )
    p_list.add_argument(
        "--unmanaged",
        action="store_true",
        help="Only show packages with at least one unmanaged file in dest",
    )
    p_list.set_defaults(func=cmd_list)

    # adopt
    p_adopt = sub.add_parser(
        "adopt",
        help="Capture files from ~ into a stow package",
        description=(
            "Copy files from your home directory into a stow package, then\n"
            "re-stow them as symlinks. Use this to capture changes made directly\n"
            "to live config files back into the dotfiles repo.\n"
            "\n"
            "Default behavior (merges into an existing package):\n"
            "  1. Delete broken symlinks under the source paths.\n"
            "  2. Copy live → stow, dereferencing symlinks (so existing stow\n"
            "     links resolve back to themselves — a no-op for unchanged files).\n"
            "  3. Unstow + re-stow with --adopt so the destination becomes\n"
            "     symlinks again, with no straggling real files.\n"
            "\n"
            "Use --overwrite to wipe the existing package directory first\n"
            "(start fresh) rather than merging. Use --dry-run to preview.\n"
            "\n"
            "Use --copy for copy-managed packages (the reverse of\n"
            "`dots install --copy`): live files are copied into stow as real\n"
            "files and re-stowing is skipped, since the live files already are\n"
            "the installed copies. Combine with --overwrite to delete the\n"
            "package directory and copy the host's contents in fresh."
        ),
        epilog=(
            "Examples:\n"
            "  dots adopt cosmic ~/.config/cosmic               # merge live state into stow\n"
            "  dots adopt --dry-run cosmic ~/.config/cosmic     # show planned changes only\n"
            "  dots adopt -o nvim ~/.config/nvim                # wipe stow/nvim and re-adopt\n"
            "  dots adopt -i tmux ~/.tmux.conf                  # adopt and re-install non-interactively\n"
            "  dots adopt -c -o cosmic ~/.config/cosmic         # refresh copy-managed pkg from host\n"
        ),
        formatter_class=fmt,
    )
    p_adopt.add_argument("package", help="Package name (created if missing)")
    p_adopt.add_argument(
        "files",
        nargs="+",
        help="Files/directories under your home to capture into the package",
    )
    p_adopt.add_argument(
        "-o",
        "--overwrite",
        action="store_true",
        help="Delete the existing stow/<package> directory before copying",
    )
    p_adopt.add_argument(
        "--dry-run",
        action="store_true",
        help="Print broken-symlink removals and add/overwrite plans without touching anything",
    )
    install_group = p_adopt.add_mutually_exclusive_group()
    install_group.add_argument(
        "-i",
        "--install",
        action="store_true",
        help="Re-stow after adopting without prompting",
    )
    install_group.add_argument(
        "-n",
        "--no-install",
        action="store_true",
        help="Skip re-stow and exit after copying",
    )
    install_group.add_argument(
        "-c",
        "--copy",
        action="store_true",
        help="Adopt as a copy-managed package: copy live files into stow as real "
        "files (no symlinks) and skip re-stowing, since the live files already are "
        "the installed copies; the reverse of `dots install --copy` (e.g. COSMIC)",
    )
    p_adopt.set_defaults(func=cmd_adopt)

    # update
    p_update = sub.add_parser(
        "update",
        help="git pull the dotfiles repo (main branch, clean tree only)",
        description=(
            "Run `git pull` in the dotfiles repository. Refuses if you're not\n"
            "on the main branch or if the working tree has uncommitted changes,\n"
            "so an update never silently clobbers in-progress edits."
        ),
        epilog="Example:\n  dots update\n",
        formatter_class=fmt,
    )
    p_update.set_defaults(func=cmd_update)

    # dir
    p_dir = sub.add_parser(
        "dir",
        help="Print the path to the dotfiles repo or a package",
        description=(
            "Print the absolute path to the dotfiles repository root, or to a\n"
            "specific package directory under stow/. Useful for shell expansion."
        ),
        epilog=(
            "Examples:\n"
            "  cd $(dots dir)            # cd into ~/.dotfiles\n"
            "  cd $(dots dir zsh)        # cd into stow/zsh\n"
        ),
        formatter_class=fmt,
    )
    p_dir.add_argument(
        "package", nargs="?", help="Package name (omit to print the repo root)"
    )
    p_dir.set_defaults(func=cmd_dir)

    # edit
    p_edit = sub.add_parser(
        "edit",
        help="Open a package directory in $EDITOR",
        description=(
            "Launch $EDITOR on stow/<package>/. Equivalent to\n"
            "`$EDITOR $(dots dir <package>)`."
        ),
        epilog="Example:\n  dots edit zsh\n",
        formatter_class=fmt,
    )
    p_edit.add_argument("package", help="Package name to edit")
    p_edit.set_defaults(func=cmd_edit)

    # deploy
    p_deploy = sub.add_parser(
        "deploy",
        help="Copy the dotfiles repo to a remote host via scp",
        description=(
            "Mirror the local dotfiles repository to a remote host with scp.\n"
            "Optionally runs bootstrap.sh on arrival to set everything up.\n"
            "If neither --bootstrap nor --no-bootstrap is given, you're prompted."
        ),
        epilog=(
            "Examples:\n"
            "  dots deploy user@host                # prompt for bootstrap\n"
            "  dots deploy --bootstrap user@host    # run bootstrap.sh automatically\n"
            "  dots deploy --no-bootstrap user@host # just copy, don't bootstrap\n"
        ),
        formatter_class=fmt,
    )
    p_deploy.add_argument("host", help="user@host to deploy to")
    bootstrap_group = p_deploy.add_mutually_exclusive_group()
    bootstrap_group.add_argument(
        "--bootstrap",
        action="store_true",
        default=None,
        help="Run bootstrap.sh on remote after copying",
    )
    bootstrap_group.add_argument(
        "--no-bootstrap",
        dest="bootstrap",
        action="store_false",
        help="Don't run bootstrap.sh on remote after copying",
    )
    p_deploy.set_defaults(func=cmd_deploy)

    # checkhealth
    p_checkhealth = sub.add_parser(
        "checkhealth",
        help="Verify the dotfiles environment is set up correctly",
        description=(
            "Run a series of sanity checks on the dotfiles environment:\n"
            "GNU Stow is installed, the repo lives where expected, the `dots`\n"
            "command is on PATH, and required tools are available."
        ),
        epilog="Example:\n  dots checkhealth\n",
        formatter_class=fmt,
    )
    p_checkhealth.set_defaults(func=cmd_checkhealth)

    # completion
    p_completion = sub.add_parser(
        "completion",
        help="Emit a shell completion script for bash or zsh",
        description=(
            "Print a shell completion script to stdout. Source it from your\n"
            "shell's rc file (or pipe to a file in your completions dir) to get\n"
            "tab-completion for subcommands, flags, and package names."
        ),
        epilog=(
            "Examples:\n"
            "  dots completion zsh >> ~/.zshrc\n"
            "  dots completion bash > /etc/bash_completion.d/dots\n"
        ),
        formatter_class=fmt,
    )
    p_completion.add_argument("shell", choices=["bash", "zsh"], help="Shell type")
    p_completion.set_defaults(func=cmd_completion)

    args = parser.parse_args()
    if args.command is None:
        parser.print_help()
        return 0
    # checkhealth checks for stow itself, so skip the stow requirement
    if args.command not in ("checkhealth", "deploy", "update", "completion"):
        check_stow()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
