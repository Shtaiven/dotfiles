[Unit]
Description=kb-kill-tray - tray icon for kb-kill
Documentation=https://github.com/seisinger/dotfiles
After=graphical-session.target kb-kill.service
Wants=kb-kill.service
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/kb-kill-tray
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
