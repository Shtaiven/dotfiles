# shellcheck shell=bash
# Bash-only sr work config. Shared sr config lives in ~/.shell.d/sr.sh.

# sr bash completion: auto-install the symlink on first use of a new machine.
# `sr completion install bash` symlinks into ~/.local/share/bash-completion/
# completions/sr, which bash-completion >= 2.10 auto-discovers.
if command -v sr >/dev/null 2>&1 \
	&& [[ ! -e "$HOME/.local/share/bash-completion/completions/sr" ]]; then
	sr completion install bash >/dev/null 2>&1
fi

# >>> mamba initialize >>>
# !! Contents within this block are managed by 'mamba init' !!
export MAMBA_EXE="$HOME/.local/bin/micromamba";
export MAMBA_ROOT_PREFIX="$HOME/micromamba";
__mamba_setup="$("$MAMBA_EXE" shell hook --shell bash --prefix "$MAMBA_ROOT_PREFIX" 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__mamba_setup"
else
    if [ -f "$HOME/micromamba/etc/profile.d/micromamba.sh" ]; then
        . "$HOME/micromamba/etc/profile.d/micromamba.sh"
    else
        export  PATH="$HOME/micromamba/bin:$PATH"  # extra space after export prevents interference from conda init
    fi
fi
unset __mamba_setup
# <<< mamba initialize <<<
